<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <!-- <link rel="stylesheet" href="/stylesheets/style.css"> -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="/edit" method="post">
                <input class="block px-5 py-5 w-1/4 rounded-md outline-none bg-zinc-700 mb-5" type="text" placeholder="Previous Name" name="previous" value ="<%= filename %>">
                <input class="block px-5 py-5 w-1/4 rounded-md outline-none bg-zinc-700 mb-5" type="text" placeholder="New Name" name="new">
                <!-- <textarea class="block resize=none px-5 py-5 w-full rounded-md outline-none bg-zinc-700" placeholder="Add your Tasks here" name="details"></textarea> -->
                <input class="border-2 mt-2 p-1 bg-yellow-600" type="submit" value="Update" id="">
            </form>
        </div>
    </div>

</body>
</html>